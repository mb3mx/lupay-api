generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  ADMIN
  USER
  CLIENT
}

enum CardBrand {
  VISA
  MASTERCARD
  AMEX
  CARNET
  OTHER
}

enum TransactionStatus {
  ACTIVE
  CANCELLED
  REFUNDED
}

enum FileType {
  TRANSACTIONS
  SETTLEMENTS
  AMEX
}

enum FileStatus {
  PENDING
  PROCESSING
  COMPLETED
  ERROR
}

enum ReconciliationStatus {
  MATCHED
  NOT_FOUND
  AMOUNT_MISMATCH
}

enum ReconciliationPriority {
  AUTHORIZATION_NUMBER
  TRANSACTION_ID
  AMOUNT_DATE
}

enum PayoutStatus {
  PENDING
  CALCULATED
  APPROVED
  PAID
}

enum LiquidacionStatus {
  CALCULADA
  APROBADA
  PAGADA
  CANCELADA
}

enum DevolucionStatus {
  PENDIENTE
  DESCONTADA
  RECHAZADA
}

enum ContracargoStatus {
  ABIERTO
  DOCUMENTADO
  RESUELTO
  PERDIDO
}

enum PaymentAccountType {
  KUSPIT
  INNTEC
  BANK
}

enum MenuItemType {
  GROUP
  COLLAPSE
  ITEM
}

// ==================== MODELS ====================

model User {
  id        BigInt   @id @default(autoincrement())
  email     String   @unique
  password  String?
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  role      UserRole @default(USER)
  isActive  Boolean  @default(false) @map("active")
  avatarUrl String?  @map("avatar_url")

  provider   String? @default("local")
  providerId String? @map("provider_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  clientId BigInt? @map("client_id")
  client   Client? @relation(fields: [clientId], references: [id])

  uploadedFiles FileControl[]

  @@unique([provider, providerId], name: "provider_providerId")
  @@index([email])
  @@index([role])
  @@index([clientId])
  @@map("user")
}

model Sindicato {
  id       BigInt  @id @default(autoincrement())
  nombre   String  @unique
  banco    String
  clabe    String  @unique
  isActive Boolean @default(true) @map("active")

  clients Client[]

  @@map("sindicato")
}

model Liquidadora {
  id          BigInt  @id @default(autoincrement())
  nombre      String  @unique
  razonSocial String  @map("razon_social")
  banco       String
  clabe       String  @unique
  isActive    Boolean @default(true) @map("active")

  clients Client[]
  liquidacionItems LiquidacionItem[]

  @@map("liquidadora")
}

model Client {
  id               BigInt  @id @default(autoincrement())
  code             String  @unique
  name             String
  businessName     String  @map("business_name")
  taxId            String? @map("tax_id")
  commissionTotal  Float   @default(0) @map("commission_total")
  afiliacion       String? @unique @map("afiliacion")
  activationEmail  String  @unique @map("activation_email")
  terminal         String? @map("terminal")
  reintegroTime    String? @map("reintegro_time")
  joinedAt         DateTime? @map("joined_at")
  comments         String?   @map("comments")

  // Contact
  contactName   String? @map("contact_name")
  contactEmail  String? @map("contact_email")
  contactPhone  String? @map("contact_phone")

  isActive Boolean @default(true) @map("active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  sindicatoId   BigInt? @map("sindicato_id")
  sindicato     Sindicato?  @relation(fields: [sindicatoId], references: [id])

  liquidadoraId BigInt? @map("liquidadora_id")
  liquidadora   Liquidadora? @relation(fields: [liquidadoraId], references: [id])

  terminals        Terminal[]
  transactions     Transaction[]
  settlements      Settlement[]
  payouts          Payout[]
  liquidacionItems LiquidacionItem[]
  users            User[]
  paymentAccounts  ClientPaymentAccount[]

  @@index([code])
  @@index([taxId])
  @@index([afiliacion])
  @@index([sindicatoId])
  @@index([liquidadoraId])
  @@map("client")
}

model ClientPaymentAccount {
  id               BigInt             @id @default(autoincrement())
  clientId         BigInt             @map("client_id")
  client           Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type             PaymentAccountType
  accountNumber    String             @map("account_number")
  holderName       String?            @map("holder_name")
  bankName         String?            @map("bank_name")
  payoutPercentage Float              @default(100.00) @map("payout_percentage")
  isActive         Boolean            @default(true) @map("is_active")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([type])
  @@map("client_payment_account")
}

model Terminal {
  id           BigInt  @id @default(autoincrement())
  serialNumber String  @unique @map("serial_number")
  model        String
  location     String?
  isActive     Boolean @default(true) @map("active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  clientId BigInt   @map("client_id")
  client   Client   @relation(fields: [clientId], references: [id])

  transactions Transaction[]
  settlements  Settlement[]

  @@index([serialNumber])
  @@index([clientId])
  @@map("terminal")
}

model FileControl {
  id             BigInt     @id @default(autoincrement())
  originalName   String     @map("original_name")
  fileName       String     @unique @map("file_name")
  fileType       FileType   @map("file_type")
  filePath       String     @map("file_path")
  fileSize       Int        @map("file_size")
  status         FileStatus @default(PENDING)
  recordCount    Int        @default(0) @map("record_count")
  processedCount Int        @default(0) @map("processed_count")
  insertedCount  Int        @default(0) @map("inserted_count")
  duplicateCount Int        @default(0) @map("duplicate_count")
  conflictCount  Int        @default(0) @map("conflict_count")
  errorMessage   String?    @map("error_message")
  resultDetails  Json?      @map("result_details")

  processedAt DateTime?  @map("processed_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  uploadedBy BigInt @map("uploaded_by")
  uploader   User   @relation(fields: [uploadedBy], references: [id])

  transactions Transaction[]
  settlements  Settlement[]

  @@index([fileType])
  @@index([status])
  @@index([uploadedBy])
  @@map("file_control")
}

model Transaction {
  id                  BigInt  @id @default(autoincrement())
  transactionId       String? @map("transaction_id")
  authorizationNumber String? @map("authorization_number")
  reference           String?

  // Amounts
  amount       Float
  fee          Float  @default(0)
  iva          Float  @default(0)
  importeLupay Float? @map("importe_lupay")

  // Transaction details
  cardBrand     CardBrand         @map("card_brand")
  cardNumber    String?           @map("card_number")
  status        TransactionStatus @default(ACTIVE)
  operationType String?           @map("operation_type")
  tipoPago      String?           @map("tipo_pago")
  afiliacion    String?           @map("afiliacion")
  merchantName  String?           @map("merchant_name")

  // Datos completos del archivo Transacciones (preservación total)
  adquiriente         String?  @map("adquiriente")
  fiid                String?  @map("fiid")
  hora                String?  @map("hora")
  modoEntrada         String?  @map("modo_entrada")
  metodoAutenticacion String?  @map("metodo_autenticacion")
  eci                 String?  @map("eci")
  tipoTarjeta         String?  @map("tipo_tarjeta")
  tasaComision        String?  @map("tasa_comision")
  tasaSobretasa       String?  @map("tasa_sobretasa")
  montoSobretasa      Float?   @map("monto_sobretasa")
  ivaSobretasa        Float?   @map("iva_sobretasa")
  sucursal            String?  @map("sucursal")
  producto            String?  @map("producto")
  terminalSerial      String?  @map("terminal_serial")
  email               String?  @map("email")
  propina             Float?   @map("propina")

  // Dates
  transactionDate DateTime  @map("transaction_date")
  liquidationDate DateTime? @map("liquidation_date")

  // Commission calculation
  clientCommission Float @default(0) @map("client_commission")
  netToClient      Float @default(0) @map("net_to_client")

  // Filter flags
  isExcluded    Boolean @default(false) @map("is_excluded")
  exclusionReason String? @map("exclusion_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  clientId BigInt  @map("client_id")
  client   Client  @relation(fields: [clientId], references: [id])

  terminalId BigInt?   @map("terminal_id")
  terminal   Terminal? @relation(fields: [terminalId], references: [id])

  fileId BigInt      @map("file_id")
  file   FileControl @relation(fields: [fileId], references: [id])

  reconciliations  Reconciliation[]
  payoutItems      PayoutItem[]
  devoluciones     Devolucion[]
  contracargos     Contracargo[]

  @@unique([transactionId, authorizationNumber, transactionDate])
  @@index([clientId])
  @@index([terminalId])
  @@index([fileId])
  @@index([transactionDate])
  @@index([authorizationNumber])
  @@index([status])
  @@index([isExcluded])
  @@index([liquidationDate])
  @@index([afiliacion])
  @@map("transaction")
}

model Settlement {
  id                  BigInt  @id @default(autoincrement())
  settlementId        String? @map("settlement_id")
  authorizationNumber String? @map("authorization_number")
  reference           String?

  // Amounts
  amount        Float
  settledAmount Float? @map("settled_amount")
  montoPagar    Float? @map("monto_pagar")

  // Details
  cardBrand  CardBrand @map("card_brand")
  status     String?
  afiliacion String?   @map("afiliacion")

  // Dates
  settlementDate  DateTime  @map("settlement_date")
  transactionDate DateTime? @map("transaction_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  clientId BigInt  @map("client_id")
  client   Client  @relation(fields: [clientId], references: [id])

  terminalId BigInt?   @map("terminal_id")
  terminal   Terminal? @relation(fields: [terminalId], references: [id])

  fileId BigInt      @map("file_id")
  file   FileControl @relation(fields: [fileId], references: [id])

  reconciliations Reconciliation[]

  @@unique([settlementId, authorizationNumber, settlementDate])
  @@index([clientId])
  @@index([terminalId])
  @@index([fileId])
  @@index([settlementDate])
  @@index([authorizationNumber])
  @@index([afiliacion])
  @@map("settlement")
}

model Reconciliation {
  id BigInt @id @default(autoincrement())

  priorityUsed     ReconciliationPriority @map("priority_used")
  status           ReconciliationStatus
  amountDifference Float?                 @map("amount_difference")
  notes            String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  transactionId BigInt      @map("transaction_id")
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  settlementId BigInt     @map("settlement_id")
  settlement   Settlement @relation(fields: [settlementId], references: [id])

  @@unique([transactionId, settlementId])
  @@index([transactionId])
  @@index([settlementId])
  @@index([status])
  @@map("reconciliation")
}

model Payout {
  id       BigInt @id @default(autoincrement())
  payoutDate DateTime @map("payout_date")

  totalAmount     Float @map("total_amount")
  totalCommission Float @map("total_commission")
  totalNet        Float @map("total_net")

  status           PayoutStatus @default(PENDING)
  paymentReference String?      @map("payment_reference")
  paidAt           DateTime?    @map("paid_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  clientId BigInt @map("client_id")
  client   Client @relation(fields: [clientId], references: [id])

  items PayoutItem[]

  @@index([clientId])
  @@index([status])
  @@index([payoutDate])
  @@map("payout")
}

model PayoutItem {
  id BigInt @id @default(autoincrement())

  grossAmount Float @map("gross_amount")
  fee         Float
  iva         Float
  commission  Float
  netAmount   Float @map("net_amount")

  createdAt DateTime @default(now()) @map("created_at")

  payoutId BigInt @map("payout_id")
  payout   Payout @relation(fields: [payoutId], references: [id], onDelete: Cascade)

  transactionId BigInt      @unique @map("transaction_id")
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  @@index([payoutId])
  @@index([transactionId])
  @@map("payout_item")
}

model Liquidacion {
  id            BigInt            @id @default(autoincrement())
  fecha         DateTime
  status        LiquidacionStatus @default(CALCULADA)
  totalBruto    Float             @map("total_bruto")
  totalComision Float             @map("total_comision")
  totalNeto     Float             @map("total_neto")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items LiquidacionItem[]

  @@index([fecha])
  @@index([status])
  @@map("liquidacion")
}

model LiquidacionItem {
  id              BigInt @id @default(autoincrement())
  montoBruto      Float  @map("monto_bruto")
  montoSettlement Float  @default(0) @map("monto_settlement")
  pctComision     Float  @map("pct_comision")
  comision        Float
  pagoNeto        Float  @map("pago_neto")

  createdAt DateTime @default(now()) @map("created_at")

  liquidacionId BigInt      @map("liquidacion_id")
  liquidacion   Liquidacion @relation(fields: [liquidacionId], references: [id], onDelete: Cascade)

  clientId BigInt @map("client_id")
  client   Client @relation(fields: [clientId], references: [id])

  liquidadoraId BigInt      @map("liquidadora_id")
  liquidadora   Liquidadora @relation(fields: [liquidadoraId], references: [id])

  @@index([liquidacionId])
  @@index([clientId])
  @@index([liquidadoraId])
  @@map("liquidacion_item")
}

model Devolucion {
  id             BigInt           @id @default(autoincrement())
  monto          Float
  status         DevolucionStatus @default(PENDIENTE)
  fechaDescuento DateTime?        @map("fecha_descuento")
  observaciones  String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  transactionId BigInt      @map("transaction_id")
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  @@index([transactionId])
  @@index([status])
  @@map("devolucion")
}

model Contracargo {
  id                BigInt            @id @default(autoincrement())
  monto             Float
  status            ContracargoStatus @default(ABIERTO)
  motivo            String?
  fechaEnvioDoc     DateTime?         @map("fecha_envio_doc")
  fechaContestacion DateTime?         @map("fecha_contestacion")
  correoContacto    String?           @map("correo_contacto")
  observaciones     String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  transactionId BigInt      @map("transaction_id")
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  @@index([transactionId])
  @@index([status])
  @@map("contracargo")
}

model MenuItem {
  id       BigInt   @id @default(autoincrement())
  parentId BigInt?  @map("parent_id")
  parent   MenuItem? @relation("MenuItemChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children MenuItem[] @relation("MenuItemChildren")

  title        String
  translateKey String?      @map("translate_key")
  type         MenuItemType @default(ITEM)
  icon         String?
  url          String?
  exactMatch   Boolean      @default(false) @map("exact_match")
  order        Int          @default(0)
  isActive     Boolean      @default(true) @map("active")
  roles        UserRole[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([parentId])
  @@map("menu_item")
}
