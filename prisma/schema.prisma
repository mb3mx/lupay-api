generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  ADMIN
  USER
}

enum CardBrand {
  VISA
  MASTERCARD
  AMEX
  OTHER
}

enum TransactionStatus {
  ACTIVE
  CANCELLED
  REFUNDED
}

enum FileType {
  TRANSACTIONS
  SETTLEMENTS
}

enum FileStatus {
  PENDING
  PROCESSING
  COMPLETED
  ERROR
}

enum ReconciliationStatus {
  MATCHED
  NOT_FOUND
  AMOUNT_MISMATCH
}

enum ReconciliationPriority {
  AUTHORIZATION_NUMBER
  TRANSACTION_ID
  AMOUNT_DATE
}

enum PayoutStatus {
  PENDING
  CALCULATED
  APPROVED
  PAID
}

// ==================== MODELS ====================

model User {
  id        BigInt   @id @default(autoincrement())
  email     String   @unique
  password  String
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  role      UserRole @default(USER)
  isActive  Boolean  @default(true) @map("active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  uploadedFiles FileControl[]

  @@index([email])
  @@index([role])
  @@map("user")
}

model Client {
  id               BigInt @id @default(autoincrement())
  code             String @unique
  name             String
  businessName     String @map("business_name")
  taxId            String @unique @map("tax_id")
  commissionTotal  Float  @default(0) @map("commission_total")

  // Contact
  contactName      String? @map("contact_name")
  contactEmail     String? @map("contact_email")
  contactPhone     String? @map("contact_phone")

  // Bank details for payouts
  bankName         String? @map("bank_name")
  bankAccount      String? @map("bank_account")
  bankClabe        String? @map("bank_clabe")

  isActive         Boolean @default(true) @map("active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  terminals Terminal[]
  transactions Transaction[]
  settlements Settlement[]
  payouts Payout[]

  @@index([code])
  @@index([taxId])
  @@map("client")
}

model Terminal {
  id            BigInt  @id @default(autoincrement())
  serialNumber  String  @unique @map("serial_number")
  model         String
  location      String?
  isActive      Boolean @default(true) @map("active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  clientId BigInt @map("client_id")
  client   Client @relation(fields: [clientId], references: [id])

  transactions Transaction[]
  settlements Settlement[]

  @@index([serialNumber])
  @@index([clientId])
  @@map("terminal")
}

model FileControl {
  id              BigInt     @id @default(autoincrement())
  originalName    String     @map("original_name")
  fileName        String     @unique @map("file_name")
  fileType        FileType   @map("file_type")
  filePath        String     @map("file_path")
  fileSize        Int        @map("file_size")
  status          FileStatus @default(PENDING)
  recordCount     Int        @default(0) @map("record_count")
  processedCount  Int        @default(0) @map("processed_count")
  errorMessage    String?    @map("error_message")

  processedAt     DateTime?  @map("processed_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  // Relations
  uploadedBy BigInt @map("uploaded_by")
  uploader   User   @relation(fields: [uploadedBy], references: [id])

  transactions Transaction[]
  settlements Settlement[]

  @@index([fileType])
  @@index([status])
  @@index([uploadedBy])
  @@map("file_control")
}

model Transaction {
  id                  BigInt @id @default(autoincrement())
  transactionId       String? @map("transaction_id")
  authorizationNumber String? @map("authorization_number")
  reference           String?

  // Amounts
  amount              Float
  fee                 Float   @default(0)
  iva                 Float   @default(0)

  // Transaction details
  cardBrand           CardBrand @map("card_brand")
  cardNumber          String?   @map("card_number")
  status              TransactionStatus @default(ACTIVE)
  operationType       String?   @map("operation_type")

  // Dates
  transactionDate     DateTime @map("transaction_date")
  liquidationDate     DateTime? @map("liquidation_date")

  // Commission calculation
  clientCommission    Float   @default(0) @map("client_commission")
  netToClient         Float   @default(0) @map("net_to_client")

  // Filter flags
  isExcluded          Boolean @default(false) @map("is_excluded")
  exclusionReason     String? @map("exclusion_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  clientId BigInt @map("client_id")
  client   Client @relation(fields: [clientId], references: [id])

  terminalId BigInt? @map("terminal_id")
  terminal   Terminal? @relation(fields: [terminalId], references: [id])

  fileId BigInt @map("file_id")
  file   FileControl @relation(fields: [fileId], references: [id])

  reconciliations Reconciliation[]
  payoutItems PayoutItem[]

  @@unique([transactionId, authorizationNumber, transactionDate])
  @@index([clientId])
  @@index([terminalId])
  @@index([fileId])
  @@index([transactionDate])
  @@index([authorizationNumber])
  @@index([status])
  @@index([isExcluded])
  @@index([liquidationDate])
  @@map("transaction")
}

model Settlement {
  id                  BigInt @id @default(autoincrement())
  settlementId        String? @map("settlement_id")
  authorizationNumber String? @map("authorization_number")
  reference           String?

  // Amounts
  amount              Float
  settledAmount       Float? @map("settled_amount")

  // Details
  cardBrand           CardBrand @map("card_brand")
  status              String?

  // Dates
  settlementDate      DateTime @map("settlement_date")
  transactionDate     DateTime? @map("transaction_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  clientId BigInt @map("client_id")
  client   Client @relation(fields: [clientId], references: [id])

  terminalId BigInt? @map("terminal_id")
  terminal   Terminal? @relation(fields: [terminalId], references: [id])

  fileId BigInt @map("file_id")
  file   FileControl @relation(fields: [fileId], references: [id])

  reconciliations Reconciliation[]

  @@unique([settlementId, authorizationNumber, settlementDate])
  @@index([clientId])
  @@index([terminalId])
  @@index([fileId])
  @@index([settlementDate])
  @@index([authorizationNumber])
  @@map("settlement")
}

model Reconciliation {
  id       BigInt @id @default(autoincrement())

  // Matching criteria used
  priorityUsed ReconciliationPriority @map("priority_used")
  status       ReconciliationStatus

  // Amount difference if mismatch
  amountDifference Float? @map("amount_difference")

  // Notes
  notes String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  transactionId BigInt @map("transaction_id")
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  settlementId BigInt @map("settlement_id")
  settlement   Settlement @relation(fields: [settlementId], references: [id])

  @@unique([transactionId, settlementId])
  @@index([transactionId])
  @@index([settlementId])
  @@index([status])
  @@map("reconciliation")
}

model Payout {
  id          BigInt @id @default(autoincrement())
  payoutDate  DateTime @map("payout_date")

  // Totals
  totalAmount     Float @map("total_amount")
  totalCommission Float @map("total_commission")
  totalNet        Float @map("total_net")

  // Status
  status PayoutStatus @default(PENDING)

  // Payment info
  paymentReference String? @map("payment_reference")
  paidAt          DateTime? @map("paid_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  clientId BigInt @map("client_id")
  client   Client @relation(fields: [clientId], references: [id])

  items PayoutItem[]

  @@index([clientId])
  @@index([status])
  @@index([payoutDate])
  @@map("payout")
}

model PayoutItem {
  id BigInt @id @default(autoincrement())

  // Amounts
  grossAmount     Float @map("gross_amount")
  fee             Float
  iva             Float
  commission      Float
  netAmount       Float @map("net_amount")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  payoutId BigInt @map("payout_id")
  payout   Payout @relation(fields: [payoutId], references: [id], onDelete: Cascade)

  transactionId BigInt @unique @map("transaction_id")
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  @@index([payoutId])
  @@index([transactionId])
  @@map("payout_item")
}
